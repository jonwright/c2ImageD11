# c2py23 interface definition for c2ImageD11
#
# Maps all ImageD11 C functions to Python signatures.
# c2py23 now natively supports all fixed-width integer types
# (int8_t, uint8_t, int16_t, uint16_t, int32_t, uint32_t,
#  int64_t, uint64_t), so thin type-adapting wrappers are no
# longer needed.  Only 2D-array-to-flat-pointer wrappers remain
# in src/wrappers/_wrappers.c for vec[3] / double[][N] parameters.

module: _cImageD11
timing: true
free_threading: true

source:
  - ../src/imageproc/blobs.c
  - ../src/geometry/cdiffraction.c
  - ../src/core/cimaged11utils.c
  - ../src/geometry/closest.c
  - ../src/imageproc/connectedpixels.c
  - ../src/imageproc/darkflat.c
  - ../src/imageproc/localmaxlabel.c
  - ../src/imageproc/sparse_image.c
  - ../src/imageproc/splat.c
  - ../src/wrappers/_wrappers.c
  - ../src/geometry/simd/score_kernel.c
  - ../src/geometry/simd/score_and_refine_kernel.c
  - ../src/geometry/simd/score_and_assign_kernel.c
  - ../src/geometry/simd/compute_gv_kernel.c
  - ../src/geometry/simd/compute_geometry_kernel.c
  - ../src/geometry/simd/compute_xlylzl_kernel.c
  - ../src/geometry/simd/compute_xlylzl_xpos_kernel.c
  - ../src/imageproc/simd/put_incr32_kernel.c
  - ../src/imageproc/simd/put_incr64_kernel.c
  - ../src/imageproc/simd/blobproperties_kernel.c
  - ../src/imageproc/simd/darksub_kernel.c
  - ../src/imageproc/simd/darkflm_kernel.c
  - ../src/imageproc/simd/reorder_f32_a32_kernel.c
  - ../src/imageproc/simd/reorderlut_f32_a32_kernel.c
  - ../src/imageproc/simd/reorder_u16_a32_kernel.c
  - ../src/imageproc/simd/reorderlut_u16_a32_kernel.c
  - ../src/bslz4/bs_master.c
  - ../src/bslz4/vendor/lz4/lib/lz4.c
  - ../src/bslz4/vendor/kcb/src/bitshuffle.c
  - ../src/bslz4/vendor/zstd/lib/common/debug.c
  - ../src/bslz4/vendor/zstd/lib/common/entropy_common.c
  - ../src/bslz4/vendor/zstd/lib/common/error_private.c
  - ../src/bslz4/vendor/zstd/lib/common/fse_decompress.c
  - ../src/bslz4/vendor/zstd/lib/common/pool.c
  - ../src/bslz4/vendor/zstd/lib/common/threading.c
  - ../src/bslz4/vendor/zstd/lib/common/xxhash.c
  - ../src/bslz4/vendor/zstd/lib/common/zstd_common.c
  - ../src/bslz4/vendor/zstd/lib/compress/fse_compress.c
  - ../src/bslz4/vendor/zstd/lib/compress/hist.c
  - ../src/bslz4/vendor/zstd/lib/compress/huf_compress.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_compress.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_compress_literals.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_compress_sequences.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_compress_superblock.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_double_fast.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_fast.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_lazy.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_ldm.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstdmt_compress.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_opt.c
  - ../src/bslz4/vendor/zstd/lib/compress/zstd_preSplit.c
  - ../src/bslz4/vendor/zstd/lib/decompress/huf_decompress.c
  - ../src/bslz4/vendor/zstd/lib/decompress/zstd_ddict.c
  - ../src/bslz4/vendor/zstd/lib/decompress/zstd_decompress_block.c
  - ../src/bslz4/vendor/zstd/lib/decompress/huf_decompress_amd64.S
  - ../src/bslz4/vendor/zstd/lib/decompress/zstd_decompress.c

headers:
  - ../src/core/cImageD11.h
  - ../src/imageproc/blobs.h
  - ../src/geometry/cdiffraction.h
  - ../src/core/ImageD11_cmath.h
  - c2py_amd64.h
  - ../src/bslz4/bs_functions.h
  - ../src/bslz4/vendor/lz4/lib/lz4.h
  - ../src/bslz4/vendor/kcb/src/bitshuffle.h
  - ../src/bslz4/vendor/zstd/lib/zstd.h
  - ../src/bslz4/vendor/zstd/lib/common/zstd_internal.h
  - ../src/bslz4/vendor/zstd/lib/common/mem.h
  - ../src/bslz4/vendor/zstd/lib/decompress/zstd_decompress_internal.h

functions:

  # ===================================================================
  # cimaged11utils.c - OpenMP thread control
  # ===================================================================

  - py_sig: "cimaged11_omp_set_num_threads(n: int) -> void"
    doc: "Set the number of OpenMP threads used by all subsequent C calls."
    params:
      n: "Number of OpenMP threads. Pass 1 for single-threaded execution."
    c_overloads:
      - sig: "void cimaged11_omp_set_num_threads(int n)"
        map: {n: n}

  - py_sig: "cimaged11_omp_get_max_threads() -> int"
    doc: "Return the maximum number of OpenMP threads available."
    c_overloads:
      - sig: "int cimaged11_omp_get_max_threads()"
        map: {}

  # ===================================================================
  # closest.c - verify_rounding, closest_vec, closest, score,
  #             score_and_refine, score_and_assign, refine_assigned,
  #             cluster1d, misori_*, count_shared
  # ===================================================================

  - py_sig: "verify_rounding(n: int) -> int"
    doc: "checks the round to nearest int code is correct"
    params:
      n: "ask jon about this parameter"
    c_overloads:
      - sig: "int verify_rounding(int n)"
        map: {n: n}

  - py_sig: "closest_vec(x: buffer, ic: buffer) -> void"
    doc: >-
      closest_vec finds the closest neighbors for each row of X
      ignoring the self. Treated as a X=[v1,v2,v3,...], computes
      sum{(vi-vj)**2} for all i!=j and places minimum in ic.
    params:
      x: "2D array of feature vectors, shape (nv, dim). Each row is a vector."
      ic: "Output array of shape (nv,). For each row i, ic[i] = index j of the nearest neighbor (j != i)."
    checks:
      - "x.format == 'd'"
      - "x.ndim == 2"
      - "x.shape[1] >= 1"
      - "ic.format == 'i'"
      - "ic.n == x.shape[0]"
    c_overloads:
      - sig: "void closest_vec(double *x, int dim, int nv, int *ic)"
        map:
          x: "x.ptr"
          dim: "x.shape[1]"
          nv: "x.shape[0]"
          ic: "ic.ptr"

  - py_sig: "closest(x: buffer, v: buffer, ibest: buffer, best: buffer) -> void"
    doc: >-
      closest finds the value and index in x closest to a value in v.
      e.g. x = cosine of angles between pairs of peaks
      v = idealised values based on hkl geometry
      ibest set to the x[i] matching to a v[j] with diff best
    params:
      x: "Array of candidate values to search (e.g. ideal cosines from hkl geometry)."
      v: "Array of values to search for (e.g. experimental cosines)."
      ibest: "Output scalar. Index into x of the closest match."
      best: "Output scalar. Minimum absolute difference |x[i] - v[j]| found."
    checks:
      - "x.format == 'd'"
      - "v.format == 'd'"
      - "ibest.format == 'i'"
      - "ibest.n == 1"
      - "best.format == 'd'"
      - "best.n == 1"
    c_overloads:
      - sig: "void closest(double *x, double *v, int *ribest, double *rbest, int nx, int nv)"
        doc: "Standard O(nx*nv) scan-find-closest."
        map:
          x: "x.ptr"
          v: "v.ptr"
          ribest: "ibest.ptr"
          rbest: "best.ptr"
          nx: "x.n"
          nv: "v.n"

  - py_sig: "score(ubi: buffer, gv: buffer, tol: float) -> int"
    doc: >-
      score takes a ubi matrix and list of g-vectors and computes
      hkl = dot(ubi, gv), then rounds these g-vectors to integer
      and computes drlv2 = (h-int(h))**2 + (k-int(k))**2 + (l-int(l))**2.
      If drlv2 is less than tol*tol then the peak is considered to
      be indexed. Returns the number of peaks found.
    params:
      ubi: "Orientation matrix UBI (UB inverse), shape (9,) flattened double. Maps g-vectors to Miller indices hkl."
      gv: "G-vectors array, shape (ng, 3) flattened. Experimental scattering vectors."
      tol: "Tolerance on |h - round(h)|. Peaks with drlv2 < tol*tol are counted."
    checks:
      - "ubi.format == 'd'"
      - "ubi.n == 9"
      - "gv.format == 'd'"
      - "gv.ndim >= 1"
    gil_release: true
    c_overloads:
      - when: "ubi.format == 'd' and gv.format == 'd'"
        map: {ubi: "ubi.ptr", gv: "gv.ptr", tol: tol, ng: "gv.shape[0]"}
        group: score
        variants:
          - name: "avx512"
            sig: "int score_avx512(const double *ubi, const double *gv, double tol, int ng) -> int"
            doc: "AVX-512 fast path (64-bit SIMD)."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "int score_avx2(const double *ubi, const double *gv, double tol, int ng) -> int"
            doc: "AVX2 fast path (256-bit SIMD)."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "int score_sse42(const double *ubi, const double *gv, double tol, int ng) -> int"
            doc: "SSE4.2 fallback (128-bit SIMD)."

  - py_sig: "score_and_refine(ubi: buffer, gv: buffer, tol: float, sumdrlv2: buffer) -> int"
    doc: >-
      score_and_refine is very similar to score but it also refines the UB
      matrix using the assigned peaks and overwrite the argument.
      It returns the number of peaks. sumdrlv2 is a 1-element buffer output.
    params:
      ubi: "Orientation matrix UBI (9-element flattened double). Overwritten with the refined best fit."
      gv: "G-vectors array, shape (ng, 3) flattened."
      tol: "Matching tolerance on |h - round(h)|."
      sumdrlv2: "Output scalar (1-element buffer). Sum of squared residuals for the matched peaks."
    checks:
      - "ubi.format == 'd'"
      - "ubi.n == 9"
      - "gv.format == 'd'"
      - "gv.ndim >= 1"
      - "sumdrlv2.format == 'd'"
      - "sumdrlv2.n == 1"
    gil_release: true
    c_overloads:
      - when: "ubi.format == 'd' and gv.format == 'd'"
        map: {ubi: "ubi.ptr", gv: "gv.ptr", tol: tol, sumdrlv2_arg: "sumdrlv2.ptr", ng: "gv.shape[0]"}
        group: score_and_refine
        variants:
          - name: "avx512"
            sig: "int score_and_refine_avx512(const double *ubi, const double *gv, double tol, double *sumdrlv2_arg, int ng) -> int"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "int score_and_refine_avx2(const double *ubi, const double *gv, double tol, double *sumdrlv2_arg, int ng) -> int"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "int score_and_refine_sse42(const double *ubi, const double *gv, double tol, double *sumdrlv2_arg, int ng) -> int"
            doc: "SSE4.2 fallback."

  - py_sig: "score_and_assign(ubi: buffer, gv: buffer, tol: float, drlv2: buffer, labels: buffer, label: int) -> int"
    doc: >-
      score_and_assign is similar to score but it assigns peaks to this
      ubi only if they fit the data better than the current UBI.
      It updates drlv2 and labels to use best fitting grain for each peak.
    params:
      ubi: "Orientation matrix (9-element flattened double)."
      gv: "G-vectors array, shape (ng, 3) flattened."
      tol: "Matching tolerance."
      drlv2: "Input/output array (ng). Current best squared residuals per peak; updated if this UBI is a better fit."
      labels: "Input/output array (ng). Current grain labels per peak; updated to label if this UBI is a better fit."
      label: "Grain label assigned to peaks that match this UBI."
    checks:
      - "ubi.format == 'd'"
      - "ubi.n == 9"
      - "gv.format == 'd'"
      - "drlv2.format == 'd'"
      - "drlv2.n == gv.shape[0]"
      - "labels.format == 'i'"
      - "labels.n == gv.shape[0]"
    gil_release: true
    c_overloads:
      - when: "ubi.format == 'd' and gv.format == 'd'"
        map: {ubi: "ubi.ptr", gv: "gv.ptr", tol: tol, drlv2: "drlv2.ptr", labels: "labels.ptr", label: label, ng: "gv.shape[0]"}
        group: score_and_assign
        variants:
          - name: "avx512"
            sig: "int score_and_assign_avx512(const double *ubi, const double *gv, double tol, double *drlv2, int *labels, int label, int ng) -> int"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "int score_and_assign_avx2(const double *ubi, const double *gv, double tol, double *drlv2, int *labels, int label, int ng) -> int"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "int score_and_assign_sse42(const double *ubi, const double *gv, double tol, double *drlv2, int *labels, int label, int ng) -> int"
            doc: "SSE4.2 fallback."

  - py_sig: "refine_assigned(ubi: buffer, gv: buffer, labels: buffer, label: int, npk: buffer, drlv2: buffer) -> void"
    doc: >-
      refine_assigned fits a ubi matrix to a set of g-vectors and assignments
      in labels. e.g. where(labels==label) it uses the peaks.
    params:
      ubi: "Orientation matrix (9-element flattened double). Overwritten with the refined UBI."
      gv: "G-vectors array, shape (ng, 3) flattened."
      labels: "Peak-to-grain assignments (ng ints). Peaks with labels[i]==label are used."
      label: "Grain label to refine. Only peaks assigned to this grain are included."
      npk: "Output scalar (1-element buffer). Number of peaks assigned to this grain."
      drlv2: "Output scalar (1-element buffer). Sum of squared residuals after refinement."
    checks:
      - "ubi.format == 'd'"
      - "ubi.n == 9"
      - "gv.format == 'd'"
      - "labels.format == 'i'"
      - "labels.n == gv.shape[0]"
      - "npk.format == 'i'"
      - "npk.n == 1"
      - "drlv2.format == 'd'"
      - "drlv2.n == 1"
    c_overloads:
      - sig: "void refine_assigned_wrapper(double *ubi, const double *gv, int *labels, int label, int *npk, double *drlv2, int ng)"
        doc: "Wrapper that casts flat double* to vec[3] for the original refine_assigned()."
        map:
          ubi: "ubi.ptr"
          gv: "gv.ptr"
          labels: "labels.ptr"
          label: label
          npk: "npk.ptr"
          drlv2: "drlv2.ptr"
          ng: "gv.shape[0]"

  - py_sig: "put_incr32(data: buffer, ind: buffer, vals: buffer, boundscheck: int = 0) -> void"
    doc: >-
      put_incr32 does the simple loop: data[ind] += vals
      uses 32 bit addressing
    params:
      data: "Destination array (float32). Updated in place with scatter-add."
      ind: "Indices array (int32). Performs data[ind[i]] += vals[i]."
      vals: "Values array (float32) to add."
      boundscheck: "If non-zero, enables bounds checking on ind. Default 0 (no check)."
    checks:
      - "data.format == 'f'"
      - "ind.format == 'i'"
      - "ind.n == vals.n"
      - "vals.format == 'f'"
    gil_release: true
    c_overloads:
      - when: "data.format == 'f' and vals.format == 'f' and ind.format == 'i'"
        map: {data: "data.ptr", ind: "ind.ptr", vals: "vals.ptr", boundscheck: boundscheck, n: "ind.n", m: "data.n"}
        group: put_incr32
        variants:
          - name: "avx512"
            sig: "void put_incr32_avx512(float *data, const int32_t *ind, const float *vals, int boundscheck, int n, int m)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void put_incr32_avx2(float *data, const int32_t *ind, const float *vals, int boundscheck, int n, int m)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void put_incr32_sse42(float *data, const int32_t *ind, const float *vals, int boundscheck, int n, int m)"
            doc: "SSE4.2 fallback."

  - py_sig: "put_incr64(data: buffer, ind: buffer, vals: buffer, boundscheck: int = 0) -> void"
    doc: >-
      put_incr64 does the simple loop: data[ind] += vals
      uses 64 bit addressing
    params:
      data: "Destination array (float32). Updated in place with scatter-add."
      ind: "Indices array (int64). Performs data[ind[i]] += vals[i]."
      vals: "Values array (float32) to add."
      boundscheck: "If non-zero, enables bounds checking on ind. Default 0 (no check)."
    checks:
      - "data.format == 'f'"
      - "ind.format == 'q' or ind.itemsize == 8"
      - "ind.n == vals.n"
      - "vals.format == 'f'"
    gil_release: true
    c_overloads:
      - when: "data.format == 'f' and vals.format == 'f'"
        map: {data: "data.ptr", ind: "ind.ptr", vals: "vals.ptr", boundscheck: boundscheck, n: "ind.n", m: "data.n"}
        group: put_incr64
        variants:
          - name: "avx512"
            sig: "void put_incr64_avx512(float *data, const int64_t *ind, const float *vals, int boundscheck, int n, int m)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void put_incr64_avx2(float *data, const int64_t *ind, const float *vals, int boundscheck, int n, int m)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void put_incr64_sse42(float *data, const int64_t *ind, const float *vals, int boundscheck, int n, int m)"
            doc: "SSE4.2 fallback."

  - py_sig: "cluster1d(ar: buffer, order: buffer, tol: float, nclusters: buffer, ids: buffer, avgs: buffer) -> void"
    doc: "cluster1d is used to find clusters of peaks. Work in progress."
    params:
      ar: "ask jon about this parameter"
      order: "ask jon about this parameter"
      tol: "ask jon about this parameter"
      nclusters: "ask jon about this parameter"
      ids: "ask jon about this parameter"
      avgs: "ask jon about this parameter"
    checks:
      - "ar.format == 'd'"
      - "order.format == 'i'"
      - "order.n == ar.n"
      - "nclusters.format == 'i'"
      - "nclusters.n == 1"
      - "ids.format == 'i'"
      - "ids.n == ar.n"
      - "avgs.format == 'd'"
      - "avgs.n == ar.n"
    c_overloads:
      - sig: "void cluster1d(double *ar, int n, int *order, double tol, int *nclusters, int *ids, double *avgs)"
        map:
          ar: "ar.ptr"
          n: "ar.n"
          order: "order.ptr"
          tol: tol
          nclusters: "nclusters.ptr"
          ids: "ids.ptr"
          avgs: "avgs.ptr"

  - py_sig: "score_gvec_z(ubi: buffer, ub: buffer, gv: buffer, g0: buffer, g1: buffer, g2: buffer, e: buffer, recompute: int) -> void"
    doc: >-
      score_gvec_z reads ubi, ub, gv and recompute.
      For all peaks it computes h = ubi.g, rounds to nearest ih = int(h)
      and then computes gcalc = ub.ih. Error is projected into
      co-ordinate system g0,g1,g2 for errors along g, z and the rhs.
    params:
      ubi: "UBI matrix (9-element flattened double). Maps g-vectors to Miller indices."
      ub: "UB matrix (9-element flattened double). Maps Miller indices back to g-vectors."
      gv: "Experimental g-vectors, shape (ng, 3) flattened."
      g0: "ask jon about this parameter"
      g1: "ask jon about this parameter"
      g2: "ask jon about this parameter"
      e: "ask jon about this parameter"
      recompute: "ask jon about this parameter"
    checks:
      - "ubi.format == 'd'"
      - "ubi.n == 9"
      - "ub.format == 'd'"
      - "ub.n == 9"
      - "gv.format == 'd'"
      - "gv.ndim >= 1"
      - "g0.format == 'd'"
      - "g0.ndim >= 1"
      - "g1.format == 'd'"
      - "g1.ndim >= 1"
      - "g2.format == 'd'"
      - "g2.ndim >= 1"
      - "e.format == 'd'"
      - "e.ndim >= 1"
    c_overloads:
      - sig: "void score_gvec_z(double *ubi, double *ub, double *gv, double *g0, double *g1, double *g2, double *e, int recompute, int n)"
        doc: "Standard scan-all-peaks path."
        map:
          ubi: "ubi.ptr"
          ub: "ub.ptr"
          gv: "gv.ptr"
          g0: "g0.ptr"
          g1: "g1.ptr"
          g2: "g2.ptr"
          e: "e.ptr"
          recompute: recompute
          n: "gv.shape[0]"

  - py_sig: "misori_cubic(u1: buffer, u2: buffer) -> float"
    doc: >-
      misori_cubic computes the trace of the smallest misorientation
      for cubic symmetry. u1 and u2 are both orientation matrices U.
    params:
      u1: "Orientation matrix U (9-element flattened double)."
      u2: "Orientation matrix U (9-element flattened double)."
    checks:
      - "u1.format == 'd'"
      - "u1.n == 9"
      - "u2.format == 'd'"
      - "u2.n == 9"
    c_overloads:
      - sig: "double misori_cubic_wrapper(const double *u1, const double *u2) -> double"
        doc: "Wrapper: casts flat double* to vec[3] for the original misori_cubic()."
        map: {u1: "u1.ptr", u2: "u2.ptr"}

  - py_sig: "misori_orthorhombic(u1: buffer, u2: buffer) -> float"
    doc: >-
      misori_orthorhombic computes the trace of the smallest misorientation.
      Looks like point group mmm.
    params:
      u1: "Orientation matrix U (9-element flattened double)."
      u2: "Orientation matrix U (9-element flattened double)."
    checks:
      - "u1.format == 'd'"
      - "u1.n == 9"
      - "u2.format == 'd'"
      - "u2.n == 9"
    c_overloads:
      - sig: "double misori_orthorhombic_wrapper(const double *u1, const double *u2) -> double"
        doc: "Wrapper: casts flat double* to vec[3]."
        map: {u1: "u1.ptr", u2: "u2.ptr"}

  - py_sig: "misori_tetragonal(u1: buffer, u2: buffer) -> float"
    doc: >-
      misori_tetragonal computes the trace of the smallest misorientation.
      Looks like point group 4/mmm.
    params:
      u1: "Orientation matrix U (9-element flattened double)."
      u2: "Orientation matrix U (9-element flattened double)."
    checks:
      - "u1.format == 'd'"
      - "u1.n == 9"
      - "u2.format == 'd'"
      - "u2.n == 9"
    c_overloads:
      - sig: "double misori_tetragonal_wrapper(const double *u1, const double *u2) -> double"
        doc: "Wrapper: casts flat double* to vec[3]."
        map: {u1: "u1.ptr", u2: "u2.ptr"}

  - py_sig: "misori_monoclinic(u1: buffer, u2: buffer) -> float"
    doc: >-
      misori_monoclinic assumes a unique b axis and only checks
      the flip of b -> -b.
    params:
      u1: "Orientation matrix U (9-element flattened double)."
      u2: "Orientation matrix U (9-element flattened double)."
    checks:
      - "u1.format == 'd'"
      - "u1.n == 9"
      - "u2.format == 'd'"
      - "u2.n == 9"
    c_overloads:
      - sig: "double misori_monoclinic_wrapper(const double *u1, const double *u2) -> double"
        doc: "Wrapper: casts flat double* to vec[3]."
        map: {u1: "u1.ptr", u2: "u2.ptr"}

  - py_sig: "count_shared(pi: buffer, pj: buffer) -> int"
    doc: >-
      count_shared takes two sorted arrays in pi and pj and counts
      how many collisions there are.
    params:
      pi: "ask jon about this parameter"
      pj: "ask jon about this parameter"
    checks:
      - "pi.format == 'i'"
      - "pj.format == 'i'"
    c_overloads:
      - sig: "int count_shared(int *pi, int ni, int *pj, int nj) -> int"
        doc: "Standard merge-scan of two sorted arrays."
        map: {pi: "pi.ptr", ni: "pi.n", pj: "pj.ptr", nj: "pj.n"}

  # ===================================================================
  # localmaxlabel.c
  # ===================================================================

  - py_sig: "localmaxlabel(data: buffer, labels: buffer, wrk: buffer) -> int"
    doc: >-
      localmaxlabel assigns a label for each pixel so they are grouped
      to the local maximum. Equal values choose to assign towards the earlier
      value in memory.
    params:
      data: "Input float32 2D image. Pixel values used to determine local maxima."
      labels: "Output int32 array (same size as data). Assigned labels for each pixel."
      wrk: "Temporary uint8 workspace (same size as data). "
    checks:
      - "data.format == 'f'"
      - "data.ndim == 2"
      - "labels.format == 'i'"
      - "labels.n == data.n"
      - "wrk.format == 'B' or wrk.format == 'b'"
      - "wrk.n == data.n"
    c_overloads:
      - sig: "int localmaxlabel(const float *im, int32_t *lout, uint8_t *l, int dim0, int dim1) -> int"
        doc: "Standard flood-fill local maximum assignment."
        map:
          im: "data.ptr"
          lout: "labels.ptr"
          l: "wrk.ptr"
          dim0: "data.shape[0]"
          dim1: "data.shape[1]"

  # ===================================================================
  # darkflat.c - uint16_to_float, frelon_lines, array_stats,
  #              array_histogram, reorder*, bgcalc
  # ===================================================================

  - py_sig: "uint16_to_float_darksub(img: buffer, drk: buffer, data: buffer) -> void"
    doc: >-
      uint16_to_float_darksub subtracts image drk(float32) from
      raw data in data (uint16) and returns in img.
    params:
      img: "Output float32 image (same size as data)."
      drk: "Dark current image (float32, same size as data)."
      data: "Raw input uint16 image."
    checks:
      - "img.format == 'f'"
      - "drk.format == 'f'"
      - "drk.n == img.n"
      - "data.format == 'H' or data.itemsize == 2"
      - "data.n == img.n"
    gil_release: true
    c_overloads:
      - when: "img.format == 'f' and drk.format == 'f'"
        map: {img: "img.ptr", drk: "drk.ptr", data: "data.ptr", npx: "img.n"}
        group: darksub
        variants:
          - name: "avx512"
            sig: "void uint16_to_float_darksub_avx512(float *img, const float *drk, const uint16_t *data, int npx)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void uint16_to_float_darksub_avx2(float *img, const float *drk, const uint16_t *data, int npx)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void uint16_to_float_darksub_sse42(float *img, const float *drk, const uint16_t *data, int npx)"
            doc: "SSE4.2 fallback."

  - py_sig: "uint16_to_float_darkflm(img: buffer, drk: buffer, flm: buffer, data: buffer) -> void"
    doc: >-
      uint16_to_float_darkflm subtracts image drk(float32) from
      raw data in data (uint16), multiplies by flm(float32) and returns in img.
      Implements: img = (data - drk) * flm.
    params:
      img: "Output float32 image."
      drk: "Dark current image (float32)."
      flm: "Flat field image (float32, multiplicative correction)."
      data: "Raw input uint16 image."
    checks:
      - "img.format == 'f'"
      - "drk.format == 'f'"
      - "drk.n == img.n"
      - "flm.format == 'f'"
      - "flm.n == img.n"
      - "data.format == 'H' or data.itemsize == 2"
      - "data.n == img.n"
    gil_release: true
    c_overloads:
      - when: "img.format == 'f' and drk.format == 'f' and flm.format == 'f'"
        map: {img: "img.ptr", drk: "drk.ptr", flm: "flm.ptr", data: "data.ptr", npx: "img.n"}
        group: darkflm
        variants:
          - name: "avx512"
            sig: "void uint16_to_float_darkflm_avx512(float *img, const float *drk, const float *flm, const uint16_t *data, int npx)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void uint16_to_float_darkflm_avx2(float *img, const float *drk, const float *flm, const uint16_t *data, int npx)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void uint16_to_float_darkflm_sse42(float *img, const float *drk, const float *flm, const uint16_t *data, int npx)"
            doc: "SSE4.2 fallback."

  - py_sig: "frelon_lines(img: buffer, cut: float) -> void"
    doc: "frelon_lines Subtracts the average value of (pixels < cut) per row"
    params:
      img: "Input/output float32 2D image. Row-dependent baseline subtracted in place."
      cut: "Threshold for selecting quiet pixels. Only pixels with value < cut are averaged to estimate row baseline."
    checks:
      - "img.format == 'f'"
      - "img.ndim == 2"
    c_overloads:
      - sig: "void frelon_lines(float *img, int ns, int nf, float cut)"
        doc: "Standard row-median stripe correction."
        map:
          img: "img.ptr"
          ns: "img.shape[0]"
          nf: "img.shape[1]"
          cut: cut

  - py_sig: "frelon_lines_sub(img: buffer, drk: buffer, cut: float) -> void"
    doc: "frelon_lines_sub Subtracts drk from img and then same as frelon_lines"
    params:
      img: "Input/output float32 2D image. Dark-subtracted, then row-baseline corrected."
      drk: "Dark current image (float32, same size as img)."
      cut: "Threshold for selecting quiet pixels."
    checks:
      - "img.format == 'f'"
      - "img.ndim == 2"
      - "drk.format == 'f'"
      - "drk.n == img.n"
    c_overloads:
      - sig: "void frelon_lines_sub(float *img, float *drk, int ns, int nf, float cut)"
        doc: "Dark-subtract then row-median stripe correction."
        map:
          img: "img.ptr"
          drk: "drk.ptr"
          ns: "img.shape[0]"
          nf: "img.shape[1]"
          cut: cut

  - py_sig: "array_mean_var_cut(img: buffer, mean: buffer, var: buffer, n: int = 3, cut: float = 3.0, verbose: int = 0) -> void"
    doc: >-
      array_mean_var_cut computes the mean and variance of an image
      with pixels above the value mean+cut*stddev removed. This is iterated
      n times as the mean and variance change as pixels are removed.
    params:
      img: "Input float32 array (1D or 2D)."
      mean: "Output scalar (1-element buffer). Computed mean of the uncontaminated pixels."
      var: "Output scalar (1-element buffer). Computed variance."
      n: "Number of sigma-clipping iterations. Default 3."
      cut: "Sigma threshold for outlier rejection in units of stddev. Default 3.0."
      verbose: "If non-zero, prints diagnostic output."
    checks:
      - "img.format == 'f'"
      - "mean.format == 'f'"
      - "mean.n == 1"
      - "var.format == 'f'"
      - "var.n == 1"
    c_overloads:
      - sig: "void array_mean_var_cut(float *img, int npx, float *mean, float *std, int n, float cut, int verbose)"
        doc: "Iterative sigma-clipped mean/var (cut threshold, no mask)."
        map:
          img: "img.ptr"
          npx: "img.n"
          mean: "mean.ptr"
          std: "var.ptr"
          n: n
          cut: cut
          verbose: verbose

  - py_sig: "array_mean_var_msk(img: buffer, msk: buffer, mean: buffer, var: buffer, n: int = 3, cut: float = 3.0, verbose: int = 0) -> void"
    doc: >-
      array_mean_var_msk computes the mean and variance of an image
      with mask. Pixels above the value mean+cut*stddev removed iteratively.
    params:
      img: "Input float32 array."
      msk: "Mask (uint8). Non-zero pixels are excluded from statistics."
      mean: "Output scalar (1-element buffer)."
      var: "Output scalar (1-element buffer)."
      n: "Number of iterations. Default 3."
      cut: "Sigma threshold. Default 3.0."
      verbose: "If non-zero, prints diagnostic output."
    checks:
      - "img.format == 'f'"
      - "msk.format == 'B' or msk.format == 'b'"
      - "msk.n == img.n"
      - "mean.format == 'f'"
      - "mean.n == 1"
      - "var.format == 'f'"
      - "var.n == 1"
    c_overloads:
      - sig: "void array_mean_var_msk(float *img, uint8_t *msk, int npx, float *mean, float *std, int n, float cut, int verbose)"
        doc: "Iterative sigma-clipped mean/var with mask."
        map:
          img: "img.ptr"
          msk: "msk.ptr"
          npx: "img.n"
          mean: "mean.ptr"
          std: "var.ptr"
          n: n
          cut: cut
          verbose: verbose

  - py_sig: "array_stats(img: buffer, minval: buffer, maxval: buffer, mean: buffer, var: buffer) -> void"
    doc: >-
      array_stats computes statistics for an image.
      img Input data array (1D or 2D.ravel(), so sparse or dense)
    params:
      img: "Input float32 array."
      minval: "Output scalar (1-element buffer). Minimum pixel value."
      maxval: "Output scalar (1-element buffer). Maximum pixel value."
      mean: "Output scalar (1-element buffer). Mean pixel value."
      var: "Output scalar (1-element buffer). Variance."
    checks:
      - "img.format == 'f'"
      - "minval.format == 'f'"
      - "minval.n == 1"
      - "maxval.format == 'f'"
      - "maxval.n == 1"
      - "mean.format == 'f'"
      - "mean.n == 1"
      - "var.format == 'f'"
      - "var.n == 1"
    c_overloads:
      - sig: "void array_stats(float *img, int npx, float *minval, float *maxval, float *mean, float *var)"
        doc: "Single-pass min/max/mean/var."
        map:
          img: "img.ptr"
          npx: "img.n"
          minval: "minval.ptr"
          maxval: "maxval.ptr"
          mean: "mean.ptr"
          var: "var.ptr"

  - py_sig: "array_histogram(img: buffer, low: float, high: float, hist: buffer) -> void"
    doc: >-
      array_histogram computes the histogram for an image.
      Go through the data to compute a histogram of the values.
    params:
      img: "Input float32 array."
      low: "Lower bound of histogram range."
      high: "Upper bound of histogram range."
      hist: "Output int32 array. Histogram bins."
    checks:
      - "img.format == 'f'"
      - "hist.format == 'i'"
    c_overloads:
      - sig: "void array_histogram(float *img, int npx, float low, float high, int32_t *hist, int nhist)"
        doc: "Linear-bin histogram."
        map:
          img: "img.ptr"
          npx: "img.n"
          low: low
          high: high
          hist: "hist.ptr"
          nhist: "hist.n"

  - py_sig: "reorder_u16_a32(data: buffer, adr: buffer, out: buffer) -> void"
    doc: >-
      reorder_u16_a32 simple loop with openmp saying out[adr[i]] in data[i].
      e.g. semi-random writing.
    params:
      data: "Input uint16 array, read in sequential order."
      adr: "Destination addresses (uint32). out[adr[i]] = data[i]."
      out: "Output uint16 array. Must be sized >= data.n."
    checks:
      - "data.format == 'H' or data.itemsize == 2"
      - "adr.format == 'I' or adr.itemsize == 4"
      - "adr.n == data.n"
      - "out.format == 'H' or out.itemsize == 2"
      - "out.n >= data.n"
    gil_release: true
    c_overloads:
      - when: "adr.format == 'I' or adr.itemsize == 4"
        map: {data: "data.ptr", adr: "adr.ptr", out: "out.ptr", N: "data.n"}
        group: reorder_u16
        variants:
          - name: "avx512"
            sig: "void reorder_u16_a32_avx512(const uint16_t *data, const uint32_t *adr, uint16_t *out, int N)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void reorder_u16_a32_avx2(const uint16_t *data, const uint32_t *adr, uint16_t *out, int N)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void reorder_u16_a32_sse42(const uint16_t *data, const uint32_t *adr, uint16_t *out, int N)"
            doc: "SSE4.2 fallback."

  - py_sig: "reorder_f32_a32(data: buffer, adr: buffer, out: buffer) -> void"
    doc: "reorder_f32_a32 simple loop with openmp saying out[adr[i]] in data[i]."
    params:
      data: "Input float32 array, read in sequential order."
      adr: "Destination addresses (uint32). out[adr[i]] = data[i]."
      out: "Output float32 array. Must be sized >= data.n."
    checks:
      - "data.format == 'f'"
      - "adr.format == 'I' or adr.itemsize == 4"
      - "adr.n == data.n"
      - "out.format == 'f'"
      - "out.n >= data.n"
    gil_release: true
    c_overloads:
      - when: "data.format == 'f' and out.format == 'f'"
        map: {data: "data.ptr", adr: "adr.ptr", out: "out.ptr", N: "data.n"}
        group: reorder_f32
        variants:
          - name: "avx512"
            sig: "void reorder_f32_a32_avx512(const float *data, const uint32_t *adr, float *out, int N)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void reorder_f32_a32_avx2(const float *data, const uint32_t *adr, float *out, int N)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void reorder_f32_a32_sse42(const float *data, const uint32_t *adr, float *out, int N)"
            doc: "SSE4.2 fallback."

  - py_sig: "reorderlut_u16_a32(data: buffer, adr: buffer, out: buffer) -> void"
    doc: "reorderlut_u16_a32 simple loop with openmp saying out[i] in data[adr[i]]."
    params:
      data: "Input uint16 array (LUT). data[adr[i]] is read for each i."
      adr: "Lookup addresses (uint32). out[i] = data[adr[i]]."
      out: "Output uint16 array. Same size as data."
    checks:
      - "data.format == 'H' or data.itemsize == 2"
      - "adr.format == 'I' or adr.itemsize == 4"
      - "adr.n == data.n"
      - "out.format == 'H' or out.itemsize == 2"
      - "out.n == data.n"
    gil_release: true
    c_overloads:
      - when: "adr.format == 'I' or adr.itemsize == 4"
        map: {data: "data.ptr", adr: "adr.ptr", out: "out.ptr", N: "data.n"}
        group: reorderlut_u16
        variants:
          - name: "avx512"
            sig: "void reorderlut_u16_a32_avx512(uint16_t *data, const uint32_t *adr, uint16_t *out, int N)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void reorderlut_u16_a32_avx2(uint16_t *data, const uint32_t *adr, uint16_t *out, int N)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void reorderlut_u16_a32_sse42(uint16_t *data, const uint32_t *adr, uint16_t *out, int N)"
            doc: "SSE4.2 fallback."

  - py_sig: "reorderlut_f32_a32(data: buffer, adr: buffer, out: buffer) -> void"
    doc: "reorderlut_f32_a32 loop with openmp saying out[i] in data[adr[i]]."
    params:
      data: "Input float32 array (LUT)."
      adr: "Lookup addresses (uint32). out[i] = data[adr[i]]."
      out: "Output float32 array. Same size as data."
    checks:
      - "data.format == 'f'"
      - "adr.format == 'I' or adr.itemsize == 4"
      - "adr.n == data.n"
      - "out.format == 'f'"
      - "out.n == data.n"
    gil_release: true
    c_overloads:
      - when: "data.format == 'f' and out.format == 'f'"
        map: {data: "data.ptr", adr: "adr.ptr", out: "out.ptr", N: "data.n"}
        group: reorderlut_f32
        variants:
          - name: "avx512"
            sig: "void reorderlut_f32_a32_avx512(const float *data, const uint32_t *adr, float *out, int N)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void reorderlut_f32_a32_avx2(const float *data, const uint32_t *adr, float *out, int N)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void reorderlut_f32_a32_sse42(const float *data, const uint32_t *adr, float *out, int N)"
            doc: "SSE4.2 fallback."

  - py_sig: "reorder_u16_a32_a16(data: buffer, adr0: buffer, adr1: buffer, out: buffer) -> void"
    doc: >-
      reorder_u16_a32_a16: data source data read in order.
      adr0 output position for the first pixel in each row.
      adr1 difference offset to output next pixel in each row.
    params:
      data: "Input uint16 2D array (ns, nf), read row by row."
      adr0: "Base addresses per row (uint32, length ns). adr0[row] = starting output position."
      adr1: "Per-pixel offsets (int16, length data.n). Cumulative difference offsets."
      out: "Output uint16 array."
    checks:
      - "data.format == 'H' or data.itemsize == 2"
      - "data.ndim == 2"
      - "adr0.format == 'I' or adr0.itemsize == 4"
      - "adr0.n == data.shape[0]"
      - "adr1.format == 'h' or adr1.itemsize == 2"
      - "adr1.n == data.n"
      - "out.format == 'H' or out.itemsize == 2"
      - "out.n >= data.n"
    c_overloads:
      - sig: "void reorder_u16_a32_a16(const uint16_t *data, const uint32_t *a0, const int16_t *a1, uint16_t *out, int ns, int nf)"
        doc: "Row-wise reroder with base+delta addressing."
        map:
          data: "data.ptr"
          a0: "adr0.ptr"
          a1: "adr1.ptr"
          out: "out.ptr"
          ns: "data.shape[0]"
          nf: "data.shape[1]"

  - py_sig: "bgcalc(img: buffer, bg: buffer, msk: buffer, gain: float, sp: float, st: float) -> void"
    doc: >-
      bgcalc computes a background on a 1d signal where gain
      and sp and st are defined by:
      diff = difference to neighbors or bg estimate
      sigmap = weight for abs background value
      sigmat = constant weight
      gain for b += diff * gain
    params:
      img: "Input float32 2D image."
      bg: "Output float32 background image (same size as img). Running background estimate."
      msk: "Output uint8 mask. 0=background, 1=positive outlier, 2=negative outlier."
      gain: "Recursive background gain factor. bg += diff * gain."
      sp: "Sigma proportional weight for background-dependent threshold. t = sp * |bg| + st."
      st: "Sigma constant weight (threshold floor)."
    checks:
      - "img.format == 'f'"
      - "img.ndim == 2"
      - "bg.format == 'f'"
      - "bg.n == img.n"
      - "msk.format == 'B' or msk.format == 'b'"
      - "msk.n == img.n"
    c_overloads:
      - sig: "void bgcalc(const float *img, float *bg, uint8_t *msk, int ns, int nf, float gain, float sigmap, float sigmat)"
        doc: "Bidirectional recursive background estimation."
        map:
          img: "img.ptr"
          bg: "bg.ptr"
          msk: "msk.ptr"
          ns: "img.shape[0]"
          nf: "img.shape[1]"
          gain: gain
          sigmap: sp
          sigmat: st

  # ===================================================================
  # cdiffraction.c - compute_geometry, compute_gv, compute_xlylzl, quickorient
  # ===================================================================

  - py_sig: "compute_geometry(xlylzl: buffer, omega: buffer, omegasign: float, wvln: float, wedge: float, chi: float, t: buffer, out: buffer) -> void"
    doc: >-
      compute_geometry is for the updateGeometry method of columnfiles.
      From xlylzl it will compute tth, eta, ds, gve into out.
      out should contain: (tth, eta, ds, gx, gy, gz).
    params:
      xlylzl: "Spot positions in laboratory frame, shape (n, 3): x, y, z."
      omega: "Omega rotation per spot (radians), shape (n,)."
      omegasign: "Omega rotation sign (+1 or -1, detector geometry)."
      wvln: "Wavelength (angstroms)."
      wedge: "Wedge angle (detector tilt, radians)."
      chi: "Chi angle (radians)."
      t: "ask jon about this parameter"
      out: "Output array shape (n, 6): tth, eta, ds, gx, gy, gz."
    checks:
      - "xlylzl.format == 'd'"
      - "xlylzl.ndim == 2"
      - "xlylzl.shape[1] == 3"
      - "omega.format == 'd'"
      - "omega.n == xlylzl.shape[0]"
      - "t.format == 'd'"
      - "t.n == 3"
      - "out.format == 'd'"
      - "out.ndim == 2"
      - "out.shape[0] == xlylzl.shape[0]"
      - "out.shape[1] == 6"
    gil_release: true
    c_overloads:
      - when: "xlylzl.format == 'd' and omega.format == 'd' and out.format == 'd'"
        map: {xlylzl: "xlylzl.ptr", omega: "omega.ptr", omegasign: omegasign, wvln: wvln, wedge: wedge, chi: chi, t: "t.ptr", out: "out.ptr", n: "xlylzl.shape[0]"}
        group: compute_geometry
        variants:
          - name: "avx512"
            sig: "void compute_geometry_avx512(const double *xlylzl, const double *omega, double omegasign, double wvln, double wedge, double chi, const double *t, double *out, int n)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void compute_geometry_avx2(const double *xlylzl, const double *omega, double omegasign, double wvln, double wedge, double chi, const double *t, double *out, int n)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void compute_geometry_sse42(const double *xlylzl, const double *omega, double omegasign, double wvln, double wedge, double chi, const double *t, double *out, int n)"
            doc: "SSE4.2 fallback."

  - py_sig: "compute_gv(xlylzl: buffer, omega: buffer, omegasign: float, wvln: float, wedge: float, chi: float, t: buffer, gv: buffer) -> void"
    doc: >-
      compute_gv computes scattering vectors given the positions of the spot
      in the laboratory in xlylzl[npks], the omega rotation[npks], and
      the rest of the parameters (wedge,wvln,chi,t[3] and omegasign).
    params:
      xlylzl: "Spot positions in laboratory frame, shape (n, 3)."
      omega: "Omega rotation per spot (radians), shape (n,)."
      omegasign: "Omega rotation sign."
      wvln: "Wavelength (angstroms)."
      wedge: "Wedge angle (radians)."
      chi: "Chi angle (radians)."
      t: "ask jon about this parameter"
      gv: "Output g-vectors array, shape (n, 3)."
    checks:
      - "xlylzl.format == 'd'"
      - "xlylzl.ndim == 2"
      - "xlylzl.shape[1] == 3"
      - "omega.format == 'd'"
      - "omega.n == xlylzl.shape[0]"
      - "t.format == 'd'"
      - "t.n == 3"
      - "gv.format == 'd'"
      - "gv.ndim == 2"
      - "gv.shape[0] == xlylzl.shape[0]"
      - "gv.shape[1] == 3"
    gil_release: true
    c_overloads:
      - when: "xlylzl.format == 'd' and omega.format == 'd' and gv.format == 'd'"
        map: {xlylzl: "xlylzl.ptr", omega: "omega.ptr", omegasign: omegasign, wvln: wvln, wedge: wedge, chi: chi, t: "t.ptr", gv: "gv.ptr", n: "xlylzl.shape[0]"}
        group: compute_gv
        variants:
          - name: "avx512"
            sig: "void compute_gv_avx512(const double *xlylzl, const double *omega, double omegasign, double wvln, double wedge, double chi, const double *t, double *gv, int n)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void compute_gv_avx2(const double *xlylzl, const double *omega, double omegasign, double wvln, double wedge, double chi, const double *t, double *gv, int n)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void compute_gv_sse42(const double *xlylzl, const double *omega, double omegasign, double wvln, double wedge, double chi, const double *t, double *gv, int n)"
            doc: "SSE4.2 fallback."

  - py_sig: "compute_xlylzl(s: buffer, f: buffer, p: buffer, r: buffer, dist: buffer, xlylzl: buffer) -> void"
    doc: >-
      compute_xlylzl finds spot positions in the laboratory frame
      using packed parameters that are more general.
      s = slow pixel position, f = fast pixel position
      p = [s_cen, f_cen, s_size, f_size]
      r[9] = dot(transform.detector_rotation_matrix, flipmatrix)
      dist = [distancex, distancey, distancez] is 3D
    params:
      s: "Slow-scan pixel positions (double array)."
      f: "Fast-scan pixel positions (double array, same size as s)."
      p: "Detector parameters (4 elements): [s_cen, f_cen, s_size, f_size]."
      r: "Rotation matrix (9 elements): det(rotation) * flip."
      dist: "Detector distance vector (3 elements): [distancex, distancey, distancez]."
      xlylzl: "Output spot positions in laboratory frame (n, 3)."
    checks:
      - "s.format == 'd'"
      - "f.format == 'd'"
      - "f.n == s.n"
      - "p.format == 'd'"
      - "p.n == 4"
      - "r.format == 'd'"
      - "r.n == 9"
      - "dist.format == 'd'"
      - "dist.n == 3"
      - "xlylzl.format == 'd'"
      - "xlylzl.ndim >= 1"
    gil_release: true
    c_overloads:
      - when: "s.format == 'd' and f.format == 'd' and xlylzl.format == 'd'"
        map: {s: "s.ptr", f: "f.ptr", p: "p.ptr", r: "r.ptr", dist: "dist.ptr", xlylzl: "xlylzl.ptr", n: "s.n"}
        group: compute_xlylzl
        variants:
          - name: "avx512"
            sig: "void compute_xlylzl_avx512(const double *s, const double *f, const double *p, const double *r, const double *dist, double *xlylzl, int n)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void compute_xlylzl_avx2(const double *s, const double *f, const double *p, const double *r, const double *dist, double *xlylzl, int n)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void compute_xlylzl_sse42(const double *s, const double *f, const double *p, const double *r, const double *dist, double *xlylzl, int n)"
            doc: "SSE4.2 fallback."

  - py_sig: "compute_xlylzl_xpos_variable(s: buffer, f: buffer, p: buffer, r: buffer, dist: buffer, xpos: buffer, xlylzl: buffer) -> void"
    doc: >-
      compute_xlylzl_xpos_variable finds spot positions in the laboratory frame
      like compute_xlylzl but with an extra per-spot x-offset xpos.
    params:
      s: "Slow-scan pixel positions (double array)."
      f: "Fast-scan pixel positions (double array)."
      p: "Detector parameters (4 elements): [s_cen, f_cen, s_size, f_size]."
      r: "Rotation matrix (9 elements)."
      dist: "Detector distance vector (3 elements)."
      xpos: "Per-spot x-axis offset (double, same size as s)."
      xlylzl: "Output spot positions in laboratory frame."
    checks:
      - "s.format == 'd'"
      - "f.format == 'd'"
      - "f.n == s.n"
      - "p.format == 'd'"
      - "p.n == 4"
      - "r.format == 'd'"
      - "r.n == 9"
      - "dist.format == 'd'"
      - "dist.n == 3"
      - "xpos.format == 'd'"
      - "xpos.n == s.n"
      - "xlylzl.format == 'd'"
      - "xlylzl.ndim >= 1"
    gil_release: true
    c_overloads:
      - when: "s.format == 'd' and f.format == 'd' and xlylzl.format == 'd'"
        map: {s: "s.ptr", f: "f.ptr", p: "p.ptr", r: "r.ptr", dist: "dist.ptr", xpos: "xpos.ptr", xlylzl: "xlylzl.ptr", n: "s.n"}
        group: compute_xlylzl_xpos
        variants:
          - name: "avx512"
            sig: "void compute_xlylzl_xpos_avx512(const double *s, const double *f, const double *p, const double *r, const double *dist, const double *xpos, double *xlylzl, int n)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void compute_xlylzl_xpos_avx2(const double *s, const double *f, const double *p, const double *r, const double *dist, const double *xpos, double *xlylzl, int n)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void compute_xlylzl_xpos_sse42(const double *s, const double *f, const double *p, const double *r, const double *dist, const double *xpos, double *xlylzl, int n)"
            doc: "SSE4.2 fallback."

  - py_sig: "quickorient(ubi: buffer, bt: buffer) -> void"
    doc: >-
      quickorient takes two g-vectors in UBI[0] and UBI[1]
      and overwrites with UBI orientation using cache in bt.
      Algorithm was due to Busing and Levy.
    params:
      ubi: "Orientation matrix (9-element flattened double). First two rows are g-vectors on entry; overwritten with UBI on exit."
      bt: "Busing-Levy cache (9-element flattened double). Crystallographic B tensor."
    checks:
      - "ubi.format == 'd'"
      - "ubi.n == 9"
      - "bt.format == 'd'"
      - "bt.n == 9"
    c_overloads:
      - sig: "void quickorient(double *ubi, const double *bt)"
        doc: "Busing-Levy orientation from two g-vectors."
        map: {ubi: "ubi.ptr", bt: "bt.ptr"}

  # ===================================================================
  # splat.c
  # ===================================================================

  - py_sig: "splat(rgba: buffer, w: int, h: int, gve: buffer, ng: int, u: buffer, npx: int) -> void"
    doc: "splat draws gvectors into an rgba image."
    params:
      rgba: "Output uint8 RGBA image buffer (h, w, 4). Zero-initialise before calling."
      w: "Image width in pixels."
      h: "Image height in pixels."
      gve: "G-vectors to draw, shape (ng, 3)."
      ng: "Number of g-vectors."
      u: "Camera projection matrix (9 elements). Projects 3D g-vectors to 2D screen."
      npx: "Marker half-size in pixels. 0=single pixel, 1=3x3 square, etc."
    checks:
      - "rgba.format == 'B' or rgba.format == 'b'"
      - "rgba.ndim >= 1"
      - "gve.format == 'd'"
      - "gve.ndim >= 1"
      - "u.format == 'd'"
      - "u.n == 9"
    c_overloads:
      - sig: "void splat_wrapper(uint8_t *rgba, int w, int h, const double *gve, int ng, const double *u, int npx)"
        doc: "Wrapper that casts flat double* to vec[3] for original splat()."
        map:
          rgba: "rgba.ptr"
          w: w
          h: h
          gve: "gve.ptr"
          ng: ng
          u: "u.ptr"
          npx: npx

  # ===================================================================
  # connectedpixels.c - connectedpixels, blobproperties, bloboverlaps,
  #                     clean_mask, make_clean_mask
  # ===================================================================

  - py_sig: "connectedpixels(data: buffer, labels: buffer, threshold: float, verbose: int = 0, con8: int = 1) -> int"
    doc: >-
      connectedpixels Determines which pixels in data are above the
      user supplied threshold and assigns them into connected objects
      which are output in labels. Connectivity is 3x3 box (8) by default
      and reduces to a +(4) if con8==0.
    params:
      data: "Input float32 2D image."
      labels: "Output int32 array (same size as data). Connected-component labels."
      threshold: "Pixel value threshold. Only pixels above threshold are labelled."
      verbose: "If non-zero, prints diagnostic output."
      con8: "Connectivity mode: 1=8-connected (3x3 box), 0=4-connected (+). Default 1."
    checks:
      - "data.format == 'f'"
      - "data.ndim == 2"
      - "labels.format == 'i'"
      - "labels.n == data.n"
    c_overloads:
      - sig: "int connectedpixels(float *data, int32_t *labels, float threshold, int verbose, int eightconnected, int ns, int nf) -> int"
        doc: "Standard connected-component labeling."
        map:
          data: "data.ptr"
          labels: "labels.ptr"
          threshold: threshold
          verbose: verbose
          eightconnected: con8
          ns: "data.shape[0]"
          nf: "data.shape[1]"

  - py_sig: "blobproperties(data: buffer, labels: buffer, np: int, results: buffer, omega: float = 0.0, verbose: int = 0) -> void"
    doc: >-
      blobproperties fills the array results with properties of each labelled
      object described by data (pixel values) and labels. The omega value
      is the angle for this frame. results shape is (np, 36).
    params:
      data: "Input float32 2D image (pixel values)."
      labels: "Connected-component labels (int32, same size as data)."
      np: "Number of labelled objects (max label value)."
      results: "Output array shape (np, 36). Per-blob properties (moments, position, etc.)."
      omega: "Omega rotation angle for this frame. Default 0.0."
      verbose: "If non-zero, prints diagnostic output."
    checks:
      - "data.format == 'f'"
      - "data.ndim == 2"
      - "labels.format == 'i'"
      - "labels.n == data.n"
      - "results.format == 'd'"
      - "results.shape[0] == np"
      - "results.shape[1] == 36"
    gil_release: true
    c_overloads:
      - when: "data.format == 'f' and labels.format == 'i' and results.format == 'd'"
        map: {data: "data.ptr", labels: "labels.ptr", npk: np, omega: omega, verbose: verbose, ns: "data.shape[0]", nf: "data.shape[1]", res: "results.ptr"}
        group: blobproperties
        variants:
          - name: "avx512"
            sig: "void blobproperties_avx512(const float *data, const int32_t *labels, int32_t npk, float omega, int verbose, int ns, int nf, double *res)"
            doc: "AVX-512 fast path."
            when: "c2py_amd64_avx512f"
          - name: "avx2"
            sig: "void blobproperties_avx2(const float *data, const int32_t *labels, int32_t npk, float omega, int verbose, int ns, int nf, double *res)"
            doc: "AVX2 fast path."
            when: "c2py_amd64_avx2"
          - name: "sse"
            sig: "void blobproperties_sse42(const float *data, const int32_t *labels, int32_t npk, float omega, int verbose, int ns, int nf, double *res)"
            doc: "SSE4.2 fallback."

  - py_sig: "bloboverlaps(labels1: buffer, npk1: int, results1: buffer, labels2: buffer, npk2: int, results2: buffer) -> int"
    doc: >-
      bloboverlaps determines the overlaps between labels1 and labels2
      for an image series. Peaks in labels2 may be merged if they were
      joined by a peak on labels1. Results in results1 are accumulated
      into results2 if peaks are overlapped.
    params:
      labels1: "Labels from first frame (int32 2D)."
      npk1: "Number of objects in first frame."
      results1: "Properties from first frame (npk1, 36). Updated if overlaps merge peaks."
      labels2: "Labels from second frame (int32, same size as labels1)."
      npk2: "Number of objects in second frame."
      results2: "Properties from second frame (npk2, 36). Accumulated if peaks are overlapped."
    checks:
      - "labels1.format == 'i'"
      - "labels1.ndim == 2"
      - "labels2.format == 'i'"
      - "labels2.n == labels1.n"
      - "results1.format == 'd'"
      - "results1.shape[0] == npk1"
      - "results1.shape[1] == 36"
      - "results2.format == 'd'"
      - "results2.shape[0] == npk2"
      - "results2.shape[1] == 36"
    c_overloads:
      - sig: "int bloboverlaps(int32_t *b1, int32_t n1, double *res1, int32_t *b2, int32_t n2, double *res2, int verbose, int ns, int nf) -> int"
        doc: "Standard overlap detection."
        map:
          b1: "labels1.ptr"
          n1: npk1
          res1: "results1.ptr"
          b2: "labels2.ptr"
          n2: npk2
          res2: "results2.ptr"
          verbose: "0"
          ns: "labels1.shape[0]"
          nf: "labels1.shape[1]"

  - py_sig: "blob_moments(results: buffer) -> void"
    doc: "blob_moments fills in the reduced moments in results array."
    params:
      results: "Input/output array (np, 36). Blob properties with raw moments; filled with reduced moments on output."
    checks:
      - "results.format == 'd'"
      - "results.ndim == 2"
      - "results.shape[1] == 36"
    c_overloads:
      - sig: "void blob_moments(double *results, int np)"
        doc: "Standard reduced-moment computation."
        map:
          results: "results.ptr"
          np: "results.shape[0]"

  - py_sig: "clean_mask(msk: buffer, ret: buffer) -> int"
    doc: >-
      clean_mask removes pixels which are not 4 connected from msk
      while copying into ret.
    params:
      msk: "Input uint8 2D mask. Isolated pixels (no 4-connected neighbors) will be removed."
      ret: "Output uint8 mask (same size as msk). Cleaned mask."
    checks:
      - "msk.format == 'b' or msk.format == 'B'"
      - "msk.ndim == 2"
      - "ret.format == 'b' or ret.format == 'B'"
      - "ret.n == msk.n"
    c_overloads:
      - sig: "int clean_mask(const int8_t *msk, int8_t *ret, int ns, int nf) -> int"
        doc: "Standard 4-connected cleanup."
        map:
          msk: "msk.ptr"
          ret: "ret.ptr"
          ns: "msk.shape[0]"
          nf: "msk.shape[1]"

  - py_sig: "make_clean_mask(img: buffer, cut: float, msk: buffer, ret: buffer) -> int"
    doc: >-
      make_clean_mask is a lot like clean_mask but it generates
      the msk using img and cut.
    params:
      img: "Input float32 2D image."
      cut: "Intensity threshold. Pixels above cut are initially included in mask."
      msk: "Input priority mask (int8). Non-zero pixels force inclusion in initial mask regardless of cut."
      ret: "Output int8 mask (same size as img). Cleaned mask after 4-connected removal."
    checks:
      - "img.format == 'f'"
      - "img.ndim == 2"
      - "msk.format == 'b' or msk.format == 'B'"
      - "msk.n == img.n"
      - "ret.format == 'b' or ret.format == 'B'"
      - "ret.n == img.n"
    c_overloads:
      - sig: "int make_clean_mask(const float *img, float cut, const int8_t *msk, int8_t *ret, int ns, int nf) -> int"
        doc: "Threshold-then-clean pipeline."
        map:
          img: "img.ptr"
          cut: cut
          msk: "msk.ptr"
          ret: "ret.ptr"
          ns: "img.shape[0]"
          nf: "img.shape[1]"

  # ===================================================================
  # sparse_image.c - mask_to_coo, sparse_is_sorted,
  #   sparse_connectedpixels*, sparse_blob2Dproperties, sparse_smooth,
  #   sparse_localmaxlabel, sparse_overlaps, compress_duplicates,
  #   coverlaps, tosparse_*
  # ===================================================================

  - py_sig: "mask_to_coo(msk: buffer, i: buffer, j: buffer, w: buffer) -> int"
    doc: >-
      mask_to_coo takes a mask and converts it to a list
      of i,j coordinates in a sparse array coo format.
      Returns: 0=>success, 1=>ns out of range, 2=>nf out of range,
      3=>nnz<1 empty mask, 4=>nnz did not match this mask.
    params:
      msk: "Input int8 2D mask. Non-zero pixels are included."
      i: "Output uint16 array. Row coordinates of active pixels."
      j: "Output uint16 array (same size as i). Column coordinates."
      w: "Output int32 array (size msk.shape[0]). Per-row count of active pixels."
    checks:
      - "msk.format == 'b' or msk.format == 'B'"
      - "msk.ndim == 2"
      - "i.format == 'H' or i.itemsize == 2"
      - "j.format == 'H' or j.itemsize == 2"
      - "j.n == i.n"
      - "w.format == 'i'"
      - "w.n == msk.shape[0]"
    c_overloads:
      - sig: "int mask_to_coo(int8_t *msk, int ns, int nf, uint16_t *i, uint16_t *j, int nnz, int *w) -> int"
        doc: "Standard mask-to-COO conversion."
        map:
          msk: "msk.ptr"
          ns: "msk.shape[0]"
          nf: "msk.shape[1]"
          i: "i.ptr"
          j: "j.ptr"
          nnz: "i.n"
          w: "w.ptr"

  - py_sig: "sparse_is_sorted(i: buffer, j: buffer) -> int"
    doc: >-
      sparse_is_sorted checks whether the indices in i and j of a sparse
      coo format come in the order that they would appear inside an image.
      Returns 0 for all OK, k for first non-sorted element,
      -k for first duplicate.
    params:
      i: "Row indices (uint16). Should be sorted in row-major order."
      j: "Column indices (uint16, same size as i)."
    checks:
      - "i.format == 'H' or i.itemsize == 2"
      - "j.format == 'H' or j.itemsize == 2"
      - "j.n == i.n"
    c_overloads:
      - sig: "int sparse_is_sorted(uint16_t *i, uint16_t *j, int nnz) -> int"
        doc: "Validation check."
        map: {i: "i.ptr", j: "j.ptr", nnz: "i.n"}

  - py_sig: "sparse_connectedpixels(v: buffer, i: buffer, j: buffer, threshold: float, labels: buffer) -> int"
    doc: >-
      sparse_connectedpixels runs the connectedpixels algorithm on
      a sparse image using a supplied threshold putting labels
      into labels array and returning the number of blobs found.
    params:
      v: "Input pixel values (float32)."
      i: "Row indices (uint16)."
      j: "Column indices (uint16, same size as i)."
      threshold: "Pixel value threshold."
      labels: "Output int32 array (same size as i). Connected-component labels."
    checks:
      - "v.format == 'f'"
      - "i.format == 'H' or i.itemsize == 2"
      - "j.format == 'H' or j.itemsize == 2"
      - "j.n == i.n"
      - "v.n == i.n"
      - "labels.format == 'i'"
      - "labels.n == i.n"
    c_overloads:
      - sig: "int sparse_connectedpixels(float *v, uint16_t *i, uint16_t *j, int nnz, float threshold, int32_t *labels) -> int"
        doc: "Sparse connected-component labeling."
        map:
          v: "v.ptr"
          i: "i.ptr"
          j: "j.ptr"
          nnz: "i.n"
          threshold: threshold
          labels: "labels.ptr"

  - py_sig: "sparse_connectedpixels_splat(v: buffer, i: buffer, j: buffer, th: float, lbl: buffer, Z: buffer, ni: int, nj: int) -> int"
    doc: >-
      sparse_connectedpixels_splat is for debugging/timing. It splats
      the sparse array into a dense array and runs the old connectedpixels
      code on that.
    params:
      v: "Input pixel values (float32)."
      i: "Row indices (uint16)."
      j: "Column indices (uint16)."
      th: "Pixel value threshold."
      lbl: "Output int32 labels array."
      Z: "Temporary int32 workspace (splat buffer, size ni*nj)."
      ni: "Number of rows in the original image."
      nj: "Number of columns in the original image."
    checks:
      - "v.format == 'f'"
      - "i.format == 'H' or i.itemsize == 2"
      - "j.format == 'H' or j.itemsize == 2"
      - "j.n == i.n"
      - "v.n == i.n"
      - "lbl.format == 'i'"
      - "lbl.n == i.n"
      - "Z.format == 'i'"
    c_overloads:
      - sig: "int sparse_connectedpixels_splat(float *v, uint16_t *i, uint16_t *j, int nnz, float threshold, int32_t *labels, int32_t *Z, int imax, int jmax) -> int"
        doc: "Dense fallback for debugging."
        map:
          v: "v.ptr"
          i: "i.ptr"
          j: "j.ptr"
          nnz: "i.n"
          threshold: th
          labels: "lbl.ptr"
          Z: "Z.ptr"
          imax: ni
          jmax: nj

  - py_sig: "sparse_blob2Dproperties(v: buffer, i: buffer, j: buffer, labels: buffer, npk: int, results: buffer) -> void"
    doc: >-
      sparse_blob2Dproperties fills the array results with properties of
      each labelled object. results shape is (npk, 11).
    params:
      v: "Input pixel values (float32)."
      i: "Row indices (uint16)."
      j: "Column indices (uint16)."
      labels: "Connected-component labels (int32)."
      npk: "Number of labelled objects."
      results: "Output array shape (npk, 11). Per-blob properties."
    checks:
      - "v.format == 'f'"
      - "i.format == 'H' or i.itemsize == 2"
      - "j.format == 'H' or j.itemsize == 2"
      - "j.n == i.n"
      - "v.n == i.n"
      - "labels.format == 'i'"
      - "labels.n == i.n"
      - "results.format == 'd'"
      - "results.shape[0] == npk"
      - "results.shape[1] == 11"
    c_overloads:
      - sig: "void sparse_blob2Dproperties(float *v, uint16_t *i, uint16_t *j, int nnz, int32_t *labels, int32_t npk, double *res)"
        doc: "Sparse 2D blob property extraction."
        map:
          v: "v.ptr"
          i: "i.ptr"
          j: "j.ptr"
          nnz: "i.n"
          labels: "labels.ptr"
          npk: npk
          res: "results.ptr"

  - py_sig: "sparse_smooth(v: buffer, i: buffer, j: buffer, s: buffer) -> void"
    doc: >-
      sparse_smooth smooths data in coo format. Workaround for avoiding
      equal pixels on peak tails for localmaxlabel. Single threaded.
    params:
      v: "Input pixel values (float32)."
      i: "Row indices (uint16)."
      j: "Column indices (uint16)."
      s: "Output smoothed values (float32, same size as v)."
    checks:
      - "v.format == 'f'"
      - "i.format == 'H' or i.itemsize == 2"
      - "j.format == 'H' or j.itemsize == 2"
      - "j.n == i.n"
      - "v.n == i.n"
      - "s.format == 'f'"
      - "s.n == i.n"
    c_overloads:
      - sig: "void sparse_smooth(float *v, uint16_t *i, uint16_t *j, int nnz, float *s)"
        doc: "Sparse smoothing."
        map:
          v: "v.ptr"
          i: "i.ptr"
          j: "j.ptr"
          nnz: "i.n"
          s: "s.ptr"

  - py_sig: "sparse_localmaxlabel(v: buffer, i: buffer, j: buffer, MV: buffer, iMV: buffer, labels: buffer) -> int"
    doc: >-
      sparse_localmaxlabel assigns labels to sparse array in sorted coo format
      supplied in (v,(i,j)). MV and iMV are temporaries. Single threaded.
    params:
      v: "Input pixel values (float32)."
      i: "Row indices (uint16)."
      j: "Column indices (uint16)."
      MV: "Temporary float32 workspace (same size as v)."
      iMV: "Temporary int32 workspace (same size as v)."
      labels: "Output int32 labels array."
    checks:
      - "v.format == 'f'"
      - "i.format == 'H' or i.itemsize == 2"
      - "j.format == 'H' or j.itemsize == 2"
      - "j.n == i.n"
      - "v.n == i.n"
      - "MV.format == 'f'"
      - "MV.n == i.n"
      - "iMV.format == 'i'"
      - "iMV.n == i.n"
      - "labels.format == 'i'"
      - "labels.n == i.n"
    c_overloads:
      - sig: "int sparse_localmaxlabel(float *v, uint16_t *i, uint16_t *j, int nnz, float *MV, int32_t *iMV, int32_t *labels) -> int"
        doc: "Sparse local maxima labeling."
        map:
          v: "v.ptr"
          i: "i.ptr"
          j: "j.ptr"
          nnz: "i.n"
          MV: "MV.ptr"
          iMV: "iMV.ptr"
          labels: "labels.ptr"

  - py_sig: "sparse_overlaps(i1: buffer, j1: buffer, k1: buffer, i2: buffer, j2: buffer, k2: buffer) -> int"
    doc: >-
      sparse_overlaps identifies the pixels in i1,j1 which overlap i2,j2.
      The list of overlaps is returned in k1/k2 such that i1[k1]==i2[k2]
      and j1[k1]==j2[k2].
    params:
      i1: "Row indices of first sparse array (uint16)."
      j1: "Column indices of first sparse array (uint16)."
      k1: "Output int32 array. Indices into i1/j1 of overlapping pixels."
      i2: "Row indices of second sparse array (uint16)."
      j2: "Column indices of second sparse array (uint16)."
      k2: "Output int32 array. Indices into i2/j2 of overlapping pixels."
    checks:
      - "i1.format == 'H' or i1.itemsize == 2"
      - "j1.format == 'H' or j1.itemsize == 2"
      - "j1.n == i1.n"
      - "k1.format == 'i'"
      - "k1.n == i1.n"
      - "i2.format == 'H' or i2.itemsize == 2"
      - "j2.format == 'H' or j2.itemsize == 2"
      - "j2.n == i2.n"
      - "k2.format == 'i'"
      - "k2.n == i2.n"
    c_overloads:
      - sig: "int sparse_overlaps(uint16_t *i1, uint16_t *j1, int *k1, int nnz1, uint16_t *i2, uint16_t *j2, int *k2, int nnz2) -> int"
        doc: "Sparse overlap detection."
        map:
          i1: "i1.ptr"
          j1: "j1.ptr"
          k1: "k1.ptr"
          nnz1: "i1.n"
          i2: "i2.ptr"
          j2: "j2.ptr"
          k2: "k2.ptr"
          nnz2: "i2.n"

  - py_sig: "compress_duplicates(i: buffer, j: buffer, oi: buffer, oj: buffer, tmp: buffer) -> int"
    doc: >-
      compress_duplicates removes duplicate i,j labels. On entry then
      i and j are set as the labels from two images. They are sorted
      and on exit i,j hold the unique pairs and oi holds the count
      for the number of overlaps. oj and tmp are temporaries.
    params:
      i: "Input/output int32. On entry: first column of (i,j) pairs. On exit: unique pairs first column."
      j: "Input/output int32. On entry: second column. On exit: unique pairs second column."
      oi: "Output int32. Count of each unique pair found (number of overlapping pixels)."
      oj: "Temporary int32 workspace for counting sort."
      tmp: "Temporary int32 workspace sized max(max(i), max(j)) + 1."
    checks:
      - "i.format == 'i'"
      - "j.format == 'i'"
      - "j.n == i.n"
      - "oi.format == 'i'"
      - "oi.n == i.n"
      - "oj.format == 'i'"
      - "oj.n == i.n"
      - "tmp.format == 'i'"
    c_overloads:
      - sig: "int compress_duplicates(int *i, int *j, int *oi, int *oj, int *tmp, int n, int nt) -> int"
        doc: "Counting-sort deduplication of (i, j) pairs."
        map:
          i: "i.ptr"
          j: "j.ptr"
          oi: "oi.ptr"
          oj: "oj.ptr"
          tmp: "tmp.ptr"
          n: "i.n"
          nt: "tmp.n"

  - py_sig: "coverlaps(row1: buffer, col1: buffer, labels1: buffer, row2: buffer, col2: buffer, labels2: buffer, mat: buffer, results: buffer) -> int"
    doc: >-
      coverlaps determines which of (row1,col1,labels1) and (row2,col2,labels2)
      are overlapped.
    params:
      row1: "Row indices of first sparse frame (uint16)."
      col1: "Column indices of first sparse frame (uint16)."
      labels1: "Peak labels for first frame (int32)."
      row2: "Row indices of second sparse frame (uint16)."
      col2: "Column indices of second sparse frame (uint16)."
      labels2: "Peak labels for second frame (int32)."
      mat: "Output int32 overlap matrix (npk1, npk2). Zero-initialise before calling."
      results: "Output int32 array for overlap triples (label1, label2, count)."
    checks:
      - "row1.format == 'H' or row1.itemsize == 2"
      - "col1.format == 'H' or col1.itemsize == 2"
      - "col1.n == row1.n"
      - "labels1.format == 'i'"
      - "labels1.n == row1.n"
      - "row2.format == 'H' or row2.itemsize == 2"
      - "col2.format == 'H' or col2.itemsize == 2"
      - "col2.n == row2.n"
      - "labels2.format == 'i'"
      - "labels2.n == row2.n"
      - "mat.format == 'i'"
      - "mat.ndim == 2"
      - "results.format == 'i'"
    c_overloads:
      - sig: "int coverlaps(uint16_t *row1, uint16_t *col1, int *labels1, int nnz1, uint16_t *row2, uint16_t *col2, int *labels2, int nnz2, int *mat, int npk1, int npk2, int *results) -> int"
        doc: "Sparse frame overlap detection."
        map:
          row1: "row1.ptr"
          col1: "col1.ptr"
          labels1: "labels1.ptr"
          nnz1: "row1.n"
          row2: "row2.ptr"
          col2: "col2.ptr"
          labels2: "labels2.ptr"
          nnz2: "row2.n"
          mat: "mat.ptr"
          npk1: "mat.shape[0]"
          npk2: "mat.shape[1]"
          results: "results.ptr"

  - py_sig: "tosparse_u16(img: buffer, msk: buffer, row: buffer, col: buffer, val: buffer, cut: int) -> int"
    doc: >-
      tosparse_u16 stores pixels from img into row/col/val.
      msk determines whether pixels are masked. Returns the number of pixels found.
    params:
      img: "Input uint16 2D image."
      msk: "Mask (uint8). Non-zero pixels are excluded."
      row: "Output uint16 array. Row coordinates of non-excluded pixels."
      col: "Output uint16 array (same size as row). Column coordinates."
      val: "Output uint16 array. Pixel values."
      cut: "Intensity threshold. Pixels <= cut are excluded."
    checks:
      - "img.format == 'H' or img.itemsize == 2"
      - "img.ndim == 2"
      - "msk.format == 'B' or msk.format == 'b' or msk.format == '?'"
      - "msk.n == img.n"
      - "row.format == 'H' or row.itemsize == 2"
      - "col.format == 'H' or col.itemsize == 2"
      - "val.format == 'H' or val.itemsize == 2"
    c_overloads:
      - sig: "int tosparse_u16(uint16_t *img, uint8_t *msk, uint16_t *row, uint16_t *col, uint16_t *val, int cut, int ns, int nf) -> int"
        doc: "Standard dense-to-sparse conversion."
        map:
          img: "img.ptr"
          msk: "msk.ptr"
          row: "row.ptr"
          col: "col.ptr"
          val: "val.ptr"
          cut: cut
          ns: "img.shape[0]"
          nf: "img.shape[1]"

  - py_sig: "tosparse_u32(img: buffer, msk: buffer, row: buffer, col: buffer, val: buffer, cut: float) -> int"
    doc: >-
      tosparse_u32 stores pixels from img into row/col/val.
      Returns the number of pixels found.
    params:
      img: "Input uint32 2D image."
      msk: "Mask (uint8). Non-zero pixels are excluded."
      row: "Output uint16 array. Row coordinates."
      col: "Output uint16 array. Column coordinates."
      val: "Output uint32 array. Pixel values."
      cut: "Intensity threshold (float). Pixels <= cut are excluded."
    checks:
      - "img.format == 'I' or img.itemsize == 4"
      - "img.ndim == 2"
      - "msk.format == 'B' or msk.format == 'b' or msk.format == '?'"
      - "msk.n == img.n"
      - "row.format == 'H' or row.itemsize == 2"
      - "col.format == 'H' or col.itemsize == 2"
      - "val.format == 'I' or val.itemsize == 4"
    c_overloads:
      - sig: "int tosparse_u32(uint32_t *img, uint8_t *msk, uint16_t *row, uint16_t *col, uint32_t *val, float cut, int ns, int nf) -> int"
        doc: "Standard dense-to-sparse conversion."
        map:
          img: "img.ptr"
          msk: "msk.ptr"
          row: "row.ptr"
          col: "col.ptr"
          val: "val.ptr"
          cut: cut
          ns: "img.shape[0]"
          nf: "img.shape[1]"

  - py_sig: "tosparse_f32(img: buffer, msk: buffer, row: buffer, col: buffer, val: buffer, cut: float) -> int"
    doc: >-
      tosparse_f32 stores pixels from img into row/col/val.
      Returns the number of pixels found.
    params:
      img: "Input float32 2D image."
      msk: "Mask (uint8). Non-zero pixels are excluded."
      row: "Output uint16 array. Row coordinates."
      col: "Output uint16 array. Column coordinates."
      val: "Output float32 array. Pixel values."
      cut: "Intensity threshold (float). Pixels <= cut are excluded."
    checks:
      - "img.format == 'f'"
      - "img.ndim == 2"
      - "msk.format == 'B' or msk.format == 'b' or msk.format == '?'"
      - "msk.n == img.n"
      - "row.format == 'H' or row.itemsize == 2"
      - "col.format == 'H' or col.itemsize == 2"
      - "val.format == 'f'"
    c_overloads:
      - sig: "int tosparse_f32(float *img, uint8_t *msk, uint16_t *row, uint16_t *col, float *val, float cut, int ns, int nf) -> int"
        doc: "Standard dense-to-sparse conversion."
        map:
          img: "img.ptr"
          msk: "msk.ptr"
          row: "row.ptr"
          col: "col.ptr"
          val: "val.ptr"
          cut: cut
          ns: "img.shape[0]"
          nf: "img.shape[1]"
