#!/bin/bash
# Pre-push hook: run fast smoke tests on master pushes.
# Install: ln -sf ../../.githooks/pre-push .git/hooks/pre-push
# Tests: buffer-protocol smoke tests (no ImageD11, no valgrind).

set -euo pipefail

ZERO_COMMIT="0000000000000000000000000000000000000000"
while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    if [ "$REMOTE_REF" = "refs/heads/master" ]; then
        MASTER_PUSH=1
    fi
done

if [ -z "${MASTER_PUSH:-}" ]; then
    exit 0
fi

echo "Running smoke tests..."
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Use the project venv if available
VENV_PYTHON="$REPO_ROOT/venv/py312/x86_64/bin/python3"
if [ -x "$VENV_PYTHON" ]; then
    PYTHON="$VENV_PYTHON"
else
    PYTHON="python3"
fi

$PYTHON -m pytest "$REPO_ROOT/tests/test_buffer.py" -v 2>&1 || {
    echo "FAILED: Smoke tests failed!"
    exit 1
}

echo "Smoke tests passed."
