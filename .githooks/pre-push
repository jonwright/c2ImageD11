#!/bin/bash
# Pre-push hook: run memory safety checks under valgrind.
# Install: ln -sf ../../.githooks/pre-push .git/hooks/pre-push
#
# Requires: valgrind
# Runs: memory tests for bslz4 C functions (small NIJ, quick)
# Exits non-zero if valgrind detects heap-buffer-overflow, invalid write, etc.

set -euo pipefail

# Only check if pushing to master
ZERO_COMMIT="0000000000000000000000000000000000000000"
while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    if [ "$LOCAL_REF" = "refs/heads/master" ]; then
        MASTER_PUSH=1
    fi
done

if [ -z "${MASTER_PUSH:-}" ]; then
    exit 0  # only check master pushes
fi

echo "Running memory safety checks (valgrind)..."
if ! command -v valgrind &>/dev/null; then
    echo "WARNING: valgrind not installed, skipping memory check"
    echo "Install: apt install valgrind"
    exit 0
fi

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# Build the extension if needed
if [ ! -f "$REPO_ROOT/c2ImageD11/_cImageD11.cpython-312-x86_64-linux-gnu.so" ]; then
    echo "Building extension..."
    python3 setup.py build_ext --inplace 2>/dev/null
fi

# Run memory test under valgrind
MEMTEST_ITERS=3 \
valgrind \
    --tool=memcheck \
    --leak-check=full \
    --error-exitcode=1 \
    --errors-for-leak-kinds=definite \
    --track-origins=yes \
    python3 -m pytest "$REPO_ROOT/tests/test_memory_bslz4.py" -v 2>&1 || {
    echo "FAILED: Memory safety check detected errors!"
    echo "Run locally: valgrind --leak-check=full --track-origins=yes"
    echo "  python3 -m pytest tests/test_memory_bslz4.py -v"
    exit 1
}

echo "Memory safety check passed."
